# ════════════════════════════════════════════
#  寵妻神器 後端環境變數
#  複製成 .env 並填入真實值
# ════════════════════════════════════════════

# ── 必填 ────────────────────────────────────
# Anthropic API Key
# 到 https://console.anthropic.com/settings/keys 取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx

# ── Supabase（強烈建議填入，讓知識庫雲端持久化）──────────────────
# 到 Supabase Dashboard → Settings → API 取得
SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
# Service Role Key（有完整寫入權限，只在後端使用，不要給前端）
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxx

# ── 選填：Email 發送功能 ────────────────────
# 到 https://resend.com 免費申請（每月 3,000 封）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# 寄件人 Email（需在 Resend 驗證的 domain）
RESEND_FROM_EMAIL=noreply@your-domain.com

# ── 選填：廠商搜尋強化 ─────────────────────
# Google Custom Search API（每天免費 100 次）
# 到 https://console.cloud.google.com → APIs → Custom Search JSON API
GOOGLE_API_KEY=AIza_xxxxxxxxxxxxxxxxxx
# Google Programmable Search Engine ID
# 到 https://programmablesearchengine.google.com 建立
GOOGLE_CSE_ID=xxxxxxxxxxxxxxxxx
